{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the AI Resume Pro application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile photo URL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user document was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Resume": {
      "title": "Resume",
      "description": "A resume created by the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the owner."
        },
        "data": {
          "type": "string",
          "description": "JSON stringified resume data."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the resume was last updated."
        }
      },
      "required": ["uid", "data", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/resumes/{resumeId}": {
      "schema": {
        "$ref": "#/entities/Resume"
      },
      "description": "Stores user resumes."
    }
  }
}
